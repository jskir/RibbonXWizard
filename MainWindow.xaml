<Window x:Class="RibbonXWizard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:RibbonXWizard.ViewModels"
        mc:Ignorable="d"
        Title="RibbonX Wizard - Office Ribbon Customization Tool" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2196F3" Padding="15" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Office RibbonX Wizard" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Create custom ribbon buttons for your Word macros" 
                           FontSize="12" Foreground="White" Opacity="0.9" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1">

            <!-- Tab 1: Configuration -->
            <TabItem Header="1. Configuration">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <!-- Source File Section -->
                        <GroupBox Header="Source File" Padding="10" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Select your .dotm file containing the macro:" 
                                           Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding SourceDotmPath, UpdateSourceTrigger=PropertyChanged}" 
                                             IsReadOnly="True" Margin="0,0,10,0" Padding="5"/>
                                    <Button Grid.Column="1" Content="Browse..." 
                                            Command="{Binding BrowseSourceFileCommand}" 
                                            Padding="15,5" MinWidth="100"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- Ribbon Button Settings -->
                        <GroupBox Header="Ribbon Button Settings" Padding="10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Target Tab -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Ribbon Tab:" 
                                           VerticalAlignment="Center" Margin="0,0,10,10"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" 
                                          ItemsSource="{Binding AvailableTabs}"
                                          SelectedItem="{Binding SelectedTab}"
                                          Margin="0,0,0,10" Padding="5"/>

                                <!-- Group Label -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Group Name:" 
                                           VerticalAlignment="Center" Margin="0,0,10,10"/>
                                <TextBox Grid.Row="1" Grid.Column="1" 
                                         Text="{Binding GroupLabel, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,0,0,10" Padding="5"/>

                                <!-- Button Label -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Button Label:" 
                                           VerticalAlignment="Center" Margin="0,0,10,10"/>
                                <TextBox Grid.Row="2" Grid.Column="1" 
                                         Text="{Binding ButtonLabel, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,0,0,10" Padding="5"/>

                                <!-- ScreenTip -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Tooltip:" 
                                           VerticalAlignment="Center" Margin="0,0,10,10"/>
                                <TextBox Grid.Row="3" Grid.Column="1" 
                                         Text="{Binding ScreenTip, UpdateSourceTrigger=PropertyChanged}" 
                                         Margin="0,0,0,10" Padding="5"/>

                                <!-- Icon -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Icon (imageMso):" 
                                           VerticalAlignment="Center" Margin="0,0,10,10"/>
                                <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,10">
                                    <TextBox Text="{Binding ImageMso, UpdateSourceTrigger=PropertyChanged}" 
                                             Padding="5"/>
                                    <TextBlock Text="Examples: MacroPlay, HappyFace, FileSave, DocumentFromFile" 
                                               FontSize="10" Foreground="Gray" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Macro Name -->
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Macro Name:" 
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel Grid.Row="5" Grid.Column="1">
                                    <TextBox Text="{Binding MacroName, UpdateSourceTrigger=PropertyChanged}" 
                                             Padding="5"/>
                                    <TextBlock Text="The exact name of the Sub procedure in your VBA code" 
                                               FontSize="10" Foreground="Gray" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <!-- Generate Button -->
                        <Button Content="Generate Ribbon Customization" 
                                Command="{Binding GenerateCommand}" 
                                Padding="20,10" FontSize="16" FontWeight="Bold"
                                Background="#4CAF50" Foreground="White"
                                BorderThickness="0" HorizontalAlignment="Center"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Generated XML -->
            <TabItem Header="2. Generated XML">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0" Text="{Binding GeneratedXml, Mode=OneWay}" 
                             IsReadOnly="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"
                             Background="#F5F5F5"/>

                    <TextBlock Grid.Row="1" Margin="0,10,0,0" 
                               Text="This XML will be embedded in your .dotm file" 
                               FontStyle="Italic" Foreground="Gray"/>
                </Grid>
            </TabItem>

            <!-- Tab 3: VBA Callback Code -->
            <TabItem Header="3. VBA Code">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0" Text="{Binding GeneratedVba, Mode=OneWay}" 
                             IsReadOnly="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"
                             Background="#F5F5F5"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Copy VBA Code" Command="{Binding CopyVbaCommand}" 
                                Padding="15,5" Margin="0,0,10,0"/>
                        <TextBlock Text="Paste this code into your .dotm file's VBA editor" 
                                   VerticalAlignment="Center" FontStyle="Italic" Foreground="Gray"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab 4: Instructions -->
            <TabItem Header="4. Instructions">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0" Text="{Binding Instructions, Mode=OneWay}" 
                             IsReadOnly="True" TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="11"
                             Background="#F5F5F5"/>

                    <Button Grid.Row="1" Content="Copy Instructions" 
                            Command="{Binding CopyInstructionsCommand}" 
                            Padding="15,5" Margin="0,10,0,0" HorizontalAlignment="Left"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Save Button (overlay at bottom) -->
        <Button Grid.Row="1" Content="💾 Save Output .dotm File" 
                Command="{Binding SaveOutputCommand}"
                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Margin="0,0,20,20" Padding="20,10" FontSize="14" FontWeight="Bold"
                Background="#FF9800" Foreground="White" BorderThickness="0"/>
    </Grid>
</Window>